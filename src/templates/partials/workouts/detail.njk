<div class="border-t border-gray-100 bg-gray-50 px-4 py-3 space-y-3">
  {% if workout.notes %}
    <p class="text-xs text-gray-500 italic">{{ workout.notes }}</p>
  {% endif %}

  {% for group in groups %}
    {% if group.type == "superset" %}
      <div class="border border-indigo-100 rounded-lg overflow-hidden">
        <div class="bg-indigo-50 px-3 py-1.5">
          <span class="text-xs font-semibold text-indigo-600 uppercase tracking-wide">Superset</span>
        </div>
        {% for lift in group.lifts %}
          <div class="px-3 py-2 {% if not loop.last %}border-b border-indigo-100{% endif %}">
            <p class="text-xs font-semibold text-gray-700 mb-1 capitalize">{{ lift.lift_name }}</p>
            <div class="space-y-0.5">
              {% for set in lift.sets %}
                <p class="text-xs text-gray-600">
                  Set {{ set.set_number }}: {{ set.reps }} reps &times; {{ set.weight }} lbs
                </p>
              {% endfor %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      {% set lift = group.lifts[0] %}
      <div>
        <p class="text-xs font-semibold text-gray-700 mb-1 capitalize">{{ lift.lift_name }}</p>
        <div class="space-y-0.5">
          {% for set in lift.sets %}
            <p class="text-xs text-gray-600">
              Set {{ set.set_number }}: {{ set.reps }} reps &times; {{ set.weight }} lbs
            </p>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  {% endfor %}

  <div class="pt-1">
    <button type="button"
            onclick="document.getElementById('detail-{{ workout.id }}').innerHTML=''"
            class="text-xs text-gray-400 hover:text-gray-600">
      &uarr; Collapse
    </button>
  </div>
</div>
