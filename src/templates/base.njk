<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Apply dark class before CSS loads to prevent flash of unstyled content -->
  <script>(function(){var m=document.cookie.match(/(?:^|;\s*)dark_mode=1(?:;|$)/);if(m)document.documentElement.classList.add('dark');}());</script>
  {% include "partials/head.njk" %}
</head>
<body class="bg-white text-gray-900 min-h-screen flex flex-col">

  {% include "partials/nav.njk" %}
  {% include "partials/header.njk" %}

  <main class="flex-1 max-w-5xl mx-auto w-full px-4 py-8 {{ 'pb-24' if user }}">
    {% block content %}{% endblock %}
  </main>

  {% include "partials/footer.njk" %}
  {% include "partials/bottom-nav.njk" %}

  <!-- HTMX — https://htmx.org -->
  <script src="https://unpkg.com/htmx.org@2.0.4" integrity="sha384-HGfztofotfshcF7+8n44JQL2oJmowVChPTg48S+jvZoztPfvwD79OC/LTtG6dMp+" crossorigin="anonymous"></script>
  <script>
    // Swap 4xx error responses so form validation errors are displayed
    htmx.config.responseHandling = [
      {code:"204", swap: false},
      {code:"[23]..", swap: true},
      {code:"4..", swap: true},
      {code:"5..", swap: false, error: true},
      {code:".*", swap: false}
    ];
  </script>
  <script>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js');
    }
  </script>
</body>
</html>
