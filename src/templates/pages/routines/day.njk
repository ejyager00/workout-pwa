{% extends "base.njk" %}

{% block content %}
<div class="max-w-lg mx-auto">

  <div class="mb-6">
    <a href="/routines" class="text-sm text-gray-500 hover:text-gray-700">&larr; All routines</a>
  </div>

  <!-- Routine name -->
  <div class="mb-6">
    <form method="POST" action="/routines/{{ day }}/name" class="flex gap-2 items-center">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
      <input type="text" name="name" value="{{ routine.name }}"
             placeholder="Routine name (e.g. Push Day)"
             maxlength="100"
             class="flex-1 border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
      <button type="submit"
              class="bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium py-2 px-3 rounded transition-colors">
        Save
      </button>
    </form>
  </div>

  <!-- Items list (htmx target) -->
  {% include "partials/routines/items-list.njk" %}

</div>
{% endblock %}
