{% extends "base.njk" %}

{% block content %}
<div class="max-w-md mx-auto mt-8">
  <h2 class="text-xl font-semibold mb-6">Create an account</h2>

  {% if error %}
    <div class="mb-4 p-3 bg-red-50 border border-red-300 text-red-700 rounded text-sm">
      {{ error }}
    </div>
  {% endif %}

  <!--
    Works as a standard HTML form POST (no JS required).
    When htmx is available, hx-post intercepts submission for a smoother UX.
  -->
  <form
    method="POST"
    action="/auth/signup"
    hx-post="/auth/signup"
    hx-target="body"
    hx-push-url="true"
    class="space-y-4"
  >
    <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

    <div>
      <label for="username" class="block text-sm font-medium text-gray-700 mb-1">
        Username
      </label>
      <input
        id="username"
        name="username"
        type="text"
        required
        minlength="3"
        maxlength="254"
        pattern="[a-zA-Z0-9_.@+\-]+"
        autocomplete="username"
        class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500"
        placeholder="you@example.com"
      />
    </div>

    <div>
      <label for="password" class="block text-sm font-medium text-gray-700 mb-1">
        Password
      </label>
      <input
        id="password"
        name="password"
        type="password"
        required
        minlength="8"
        maxlength="128"
        autocomplete="new-password"
        class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500"
        placeholder="At least 8 characters"
      />
    </div>

    <!-- Cloudflare Turnstile widget -->
    <div
      class="cf-turnstile"
      data-sitekey="{{ turnstileSiteKey }}"
      data-callback="onTurnstileSuccess"
    ></div>
    <input type="hidden" name="turnstileToken" id="turnstileToken" />

    <button
      type="submit"
      class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2 px-4 rounded text-sm transition-colors"
    >
      Sign up
    </button>
  </form>

  <p class="mt-4 text-sm text-gray-600 text-center">
    Already have an account?
    <a href="/auth/login" class="text-indigo-600 hover:underline">Log in</a>
  </p>

  <p class="mt-4 text-xs text-gray-500 text-center leading-relaxed">
    Use a <strong>unique password</strong> you don't use elsewhere — there is no password recovery,
    and forgotten passwords cannot be retrieved.
    <a href="/about#disclaimers" class="text-indigo-500 hover:underline">Full disclaimers &rarr;</a>
  </p>
</div>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
<script>
  function onTurnstileSuccess(token) {
    document.getElementById('turnstileToken').value = token;
  }
</script>
{% endblock %}
