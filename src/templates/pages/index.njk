{% extends "base.njk" %}

{% block content %}
<div class="max-w-lg mx-auto">

  {% if routine and routine.name %}
    <p class="text-sm text-gray-500 -mt-4 mb-5">{{ routine.name }}</p>
  {% elif not routine %}
    <div class="mb-5 p-3 bg-amber-50 border border-amber-200 rounded-lg text-sm text-amber-800">
      No routine for {{ dayName }}.
      <a href="/routines/{{ weekday }}" class="font-medium underline">Set one up →</a>
    </div>
  {% endif %}

  {% if completed %}
    <div class="mb-5 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-800 font-medium">
      ✓ Workout complete for today!
    </div>
  {% endif %}

  {% include "partials/home/lifts-panel.njk" %}

</div>
{% endblock %}
