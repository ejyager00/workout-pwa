{% extends "base.njk" %}

{% block content %}
<div class="max-w-2xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-xl font-semibold">My Notes</h2>
    <a
      href="/notes/new"
      class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium py-2 px-4 rounded transition-colors"
    >
      + New Note
    </a>
  </div>

  {% if notes.length === 0 %}
    <p class="text-gray-500 text-sm">No notes yet. <a href="/notes/new" class="text-indigo-600 hover:underline">Create your first note.</a></p>
  {% else %}
    <ul class="divide-y divide-gray-200 border border-gray-200 rounded" id="notes-list">
      {% for note in notes %}
        <li class="flex items-center justify-between px-4 py-3 hover:bg-gray-50">
          <a href="/notes/{{ note.id }}" class="text-sm font-medium text-gray-900 hover:text-indigo-600 truncate flex-1">
            {{ note.title }}
          </a>
          <form
            method="POST"
            action="/notes/{{ note.id }}/delete"
            class="ml-4 flex-shrink-0"
            hx-post="/notes/{{ note.id }}/delete"
            hx-target="#notes-list"
            hx-swap="outerHTML"
            hx-confirm="Delete this note?"
          >
            <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
            <button
              type="submit"
              class="text-xs text-red-500 hover:text-red-700 transition-colors"
            >
              Delete
            </button>
          </form>
        </li>
      {% endfor %}
    </ul>
  {% endif %}
</div>
{% endblock %}
