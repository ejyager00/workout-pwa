{% extends "base.njk" %}

{% block content %}
<div class="max-w-2xl mx-auto">
  <h2 class="text-xl font-semibold mb-6">{{ title }}</h2>

  {% if error %}
    <div class="mb-4 p-3 bg-red-50 border border-red-300 text-red-700 rounded text-sm">
      {{ error }}
    </div>
  {% endif %}

  <!--
    Works as a standard HTML form POST (no JS required).
    When HTMX is available, hx-post intercepts submission for a smoother UX.
  -->
  <form
    method="POST"
    action="{{ action }}"
    hx-post="{{ action }}"
    hx-target="body"
    hx-push-url="true"
    class="space-y-4"
  >
    <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

    <div>
      <label for="title" class="block text-sm font-medium text-gray-700 mb-1">
        Title <span class="text-red-500">*</span>
      </label>
      <input
        id="title"
        name="title"
        type="text"
        required
        maxlength="200"
        value="{{ note.title if note else '' }}"
        class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500"
        placeholder="Note title"
      />
    </div>

    <div>
      <label for="body" class="block text-sm font-medium text-gray-700 mb-1">
        Body
      </label>
      <textarea
        id="body"
        name="body"
        rows="10"
        maxlength="10000"
        class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 font-mono"
        placeholder="Write your note here..."
      >{{ note.body if note else '' }}</textarea>
    </div>

    <div class="flex items-center gap-3">
      <button
        type="submit"
        class="bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2 px-4 rounded text-sm transition-colors"
      >
        {{ "Save changes" if note else "Create note" }}
      </button>
      <a
        href="{{ '/notes/' + note.id if note else '/notes' }}"
        class="text-sm text-gray-500 hover:text-gray-700"
      >
        Cancel
      </a>
    </div>
  </form>
</div>
{% endblock %}
