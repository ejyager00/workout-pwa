{
	"name": "htmx-crud-worker-template",
	"description": "Reusable Cloudflare Worker template: Hono + HTMX + D1 + KV + Nunjucks + auth",
	"private": true,
	"scripts": {
		"build": "npm run precompile && npm run tailwind:build",
		"precompile": "node scripts/precompile-templates.js",
		"tailwind:build": "tailwindcss --input src/styles/app.css --output public/app.css --minify",
		"tailwind:watch": "tailwindcss --input src/styles/app.css --output public/app.css --watch",
		"dev": "npm run build && concurrently \"wrangler dev\" \"npm run tailwind:watch\"",
		"deploy": "npm run build && wrangler deploy",
		"setup": "node scripts/setup.js",
		"types": "wrangler types",
		"test": "vitest run",
		"test:watch": "vitest",
		"db:migrate:dev": "wrangler d1 migrations apply DB --local",
		"db:migrate:prod": "wrangler d1 migrations apply DB --remote"
	},
	"dependencies": {
		"@hono/zod-validator": "^0.7.6",
		"hono": "^4.12.4",
		"nunjucks": "^3.2.4",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.12.18",
		"@tailwindcss/cli": "^4.x",
		"@types/node": "^25.3.3",
		"@types/nunjucks": "^3.2.6",
		"concurrently": "^9.x",
		"tailwindcss": "^4.x",
		"typescript": "5.9.3",
		"vitest": "^3.2.0",
		"wrangler": "^4.70.0"
	}
}